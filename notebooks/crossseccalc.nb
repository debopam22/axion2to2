Cell[BoxData[
 RowBox[{"-", 
  FractionBox[
   RowBox[{
    SuperscriptBox["gaaa", "2"], " ", 
    SuperscriptBox["qe", "2"], " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"2", " ", 
       SuperscriptBox["mN", "4"], " ", "t"}], "+", 
      RowBox[{"2", " ", 
       SuperscriptBox["mN", "2"], " ", 
       RowBox[{"(", 
        RowBox[{
         SuperscriptBox["mphi", "4"], "-", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            SuperscriptBox["mphi", "2"], "+", 
            RowBox[{"2", " ", "s"}]}], ")"}], " ", "t"}]}], ")"}]}], "+", 
      RowBox[{"t", " ", 
       RowBox[{"(", 
        RowBox[{
         SuperscriptBox["mphi", "4"], "+", 
         RowBox[{"2", " ", 
          SuperscriptBox["s", "2"]}], "+", 
         RowBox[{"2", " ", "s", " ", "t"}], "+", 
         SuperscriptBox["t", "2"], "-", 
         RowBox[{"2", " ", 
          SuperscriptBox["mphi", "2"], " ", 
          RowBox[{"(", 
           RowBox[{"s", "+", "t"}], ")"}]}]}], ")"}]}]}], ")"}], " ", 
    SuperscriptBox["Z", "2"]}], 
   RowBox[{"2", " ", 
    SuperscriptBox["t", "2"]}]]}]], "Output",
