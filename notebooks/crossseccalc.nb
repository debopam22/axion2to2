Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"Amp1", "=", 
   RowBox[{"gaee", "*", 
    FractionBox["qe", 
     RowBox[{"2", "*", 
      RowBox[{"ScalarProduct", "[", 
       RowBox[{"p1", ",", "p2"}], "]"}]}]], "*", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"SpinorUBar", "[", 
       RowBox[{"k2", ",", "me"}], "]"}], ".", 
      RowBox[{"GA", "[", "5", "]"}], ".", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"GS", "[", "p1", "]"}], "+", 
