Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"Amp1", "=", 
   RowBox[{"Z", "*", "qe", "*", "gaaa", "*", 
    FractionBox["1", 
     RowBox[{
      RowBox[{"ScalarProduct", "[", 
       RowBox[{"p2", ",", "p2"}], "]"}], "+", 
      RowBox[{"ScalarProduct", "[", 
       RowBox[{"k2", ",", "k2"}], "]"}], "-", 
      RowBox[{"2", "*", 
       RowBox[{"ScalarProduct", "[", 
        RowBox[{"p2", ",", "k2"}], "]"}]}]}]], "*", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"SpinorUBar", "[", 
       RowBox[{"k2", ",", "mN"}], "]"}], ".", 
      RowBox[{"GA", "[", "\[Mu]", "]"}], ".", 
      RowBox[{"SpinorU", "[", 
       RowBox[{"p2", ",", "mN"}], "]"}]}], ")"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Amp2", "=", 
   RowBox[{
    RowBox[{"Eps", "[", 
     RowBox[{
      RowBox[{"LorentzIndex", "[", "\[Mu]", "]"}], ",", " ", 
      RowBox[{"LorentzIndex", "[", "\[Nu]", "]"}], ",", " ", 
      RowBox[{"LorentzIndex", "[", "\[Rho]", "]"}], ",", " ", 
      RowBox[{"LorentzIndex", "[", "\[Sigma]", "]"}]}], "]"}], "*", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"FV", "[", 
       RowBox[{"p2", ",", " ", "\[Rho]"}], "]"}], "-", 
      RowBox[{"FV", "[", 
       RowBox[{"k2", ",", "\[Rho]"}], "]"}]}], ")"}], "*", 
    RowBox[{"FV", "[", 
     RowBox[{"p1", ",", " ", "\[Sigma]"}], "]"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"CompConjAmp1", "=", 
   RowBox[{"ComplexConjugate", "[", 
    RowBox[{"Amp1", "/.", 
     RowBox[{"{", 
      RowBox[{"\[Mu]", "->", "\[Alpha]"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"CompConjAmp2", "=", 
   RowBox[{"ComplexConjugate", "[", 
    RowBox[{"Amp2", "/.", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"\[Mu]", "->", "\[Alpha]"}], ",", 
       RowBox[{"\[Nu]", "->", "\[Beta]"}]}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"SetMandelstam", "[", 
   RowBox[{"s", ",", "t", ",", "u", ",", "p1", ",", "p2", ",", 
    RowBox[{"-", "k1"}], ",", 
    RowBox[{"-", "k2"}], ",", "0", ",", "mN", ",", "mphi", ",", "mN"}], "]"}],
   ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Res1", "=", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{"Contract", "[", 
     RowBox[{"DiracSimplify", "[", 
      RowBox[{"FermionSpinSum", "[", 
       RowBox[{
        FractionBox["1", "4"], "*", 
        RowBox[{"Amp1", ".", "CompConjAmp1"}]}], "]"}], "]"}], "]"}], "]"}]}],
   ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Res2", "=", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{"Contract", "[", 
     RowBox[{"DiracSimplify", "[", 
      RowBox[{"FermionSpinSum", "[", 
       RowBox[{"Amp2", ".", "CompConjAmp2", ".", 
        RowBox[{"MT", "[", 
         RowBox[{"\[Nu]", ",", "\[Beta]"}], "]"}]}], "]"}], "]"}], "]"}], 
    "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Amp2", "=", 
  RowBox[{"FullSimplify", "[", 
   RowBox[{
    RowBox[{"Contract", "[", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"-", "1"}], ")"}], "*", 
      RowBox[{"Res1", ".", "Res2"}]}], "]"}], "/.", 
    RowBox[{"{", 
     RowBox[{"u", "->", 
      RowBox[{
       RowBox[{"2", "*", 
        SuperscriptBox["mN", "2"]}], "+", 
       SuperscriptBox["mphi", "2"], "-", "s", "-", "t"}]}], "}"}]}], 
   "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"dsigmadt", "=", 
   FractionBox["Amp2", 
    RowBox[{"64", "*", "Pi", "*", 
     FractionBox[
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"s", "-", 
         SuperscriptBox["mN", "2"]}], ")"}], "2"], "4"]}]]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"Amp3", "=", 
  RowBox[{"FullSimplify", "[", 
   RowBox[{"dsigmadt", "/.", 
    RowBox[{"{", 
     RowBox[{"s", "->", 
      RowBox[{
       SuperscriptBox["mN", "2"], "+", 
       RowBox[{"2", "*", "Ega", "*", "mN"}]}]}], "}"}]}], "]"}]}]}], "Input",
 CellChangeTimes->{{3.982922563925705*^9, 3.982922581085106*^9}, {
   3.9829228134898653`*^9, 3.9829228171982193`*^9}, {3.982922864335019*^9, 
   3.98292286568486*^9}, 3.982922910642864*^9},
 CellLabel->"In[2]:=",ExpressionUUID->"f4a00058-5c60-44c2-bc28-a15f94f89a0e"],

Cell[BoxData[
 RowBox[{"-", 
  FractionBox[
   RowBox[{
    SuperscriptBox["gaaa", "2"], " ", 
    SuperscriptBox["qe", "2"], " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"2", " ", 
       SuperscriptBox["mN", "4"], " ", "t"}], "+", 
      RowBox[{"2", " ", 
       SuperscriptBox["mN", "2"], " ", 
       RowBox[{"(", 
        RowBox[{
         SuperscriptBox["mphi", "4"], "-", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            SuperscriptBox["mphi", "2"], "+", 
            RowBox[{"2", " ", "s"}]}], ")"}], " ", "t"}]}], ")"}]}], "+", 
      RowBox[{"t", " ", 
       RowBox[{"(", 
        RowBox[{
         SuperscriptBox["mphi", "4"], "+", 
         RowBox[{"2", " ", 
          SuperscriptBox["s", "2"]}], "+", 
         RowBox[{"2", " ", "s", " ", "t"}], "+", 
         SuperscriptBox["t", "2"], "-", 
         RowBox[{"2", " ", 
          SuperscriptBox["mphi", "2"], " ", 
          RowBox[{"(", 
           RowBox[{"s", "+", "t"}], ")"}]}]}], ")"}]}]}], ")"}], " ", 
    SuperscriptBox["Z", "2"]}], 
   RowBox[{"4", " ", 
    SuperscriptBox["t", "2"]}]]}]], "Output",
 CellChangeTimes->{
  3.9580208745256977`*^9, {3.982922906765387*^9, 3.982922919455501*^9}},
 CellLabel->"Out[9]=",ExpressionUUID->"17f9d2b4-cfea-4d97-95f8-bafc511ea4c8"],

Cell[BoxData[
 RowBox[{"-", 
  FractionBox[
   RowBox[{
    SuperscriptBox["gaaa", "2"], " ", 
    SuperscriptBox["qe", "2"], " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{
          SuperscriptBox["mphi", "2"], "-", "t"}], ")"}], "2"], " ", "t"}], 
      "+", 
      RowBox[{"4", " ", "Ega", " ", "mN", " ", "t", " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", 
          SuperscriptBox["mphi", "2"]}], "+", "t"}], ")"}]}], "+", 
      RowBox[{"2", " ", 
       SuperscriptBox["mN", "2"], " ", 
       RowBox[{"(", 
        RowBox[{
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{
            SuperscriptBox["mphi", "2"], "-", "t"}], ")"}], "2"], "+", 
         RowBox[{"4", " ", 
          SuperscriptBox["Ega", "2"], " ", "t"}]}], ")"}]}]}], ")"}], " ", 
    SuperscriptBox["Z", "2"]}], 
   RowBox[{"256", " ", 
    SuperscriptBox["Ega", "2"], " ", 
    SuperscriptBox["mN", "2"], " ", "\[Pi]", " ", 
    SuperscriptBox["t", "2"]}]]}]], "Output",
 CellChangeTimes->{
  3.9580208745256977`*^9, {3.982922906765387*^9, 3.98292291953822*^9}},
 CellLabel->"Out[11]=",ExpressionUUID->"be89edd4-f15b-40d4-85c0-2a0f13485e62"]
}, Open  ]],

