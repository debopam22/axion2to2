Cell[BoxData[{
 RowBox[{
  RowBox[{"Amp1", "=", 
   RowBox[{"gaee", "*", 
    FractionBox["qe", 
     RowBox[{
      SuperscriptBox["ma", "2"], "-", 
      RowBox[{"2", "*", 
       RowBox[{"ScalarProduct", "[", 
        RowBox[{"p1", ",", "k2"}], "]"}]}]}]], "*", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"SpinorUBar", "[", 
       RowBox[{"k2", ",", "me"}], "]"}], ".", 
      RowBox[{"GA", "[", "5", "]"}], ".", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"GS", "[", "k2", "]"}], "-", 
        RowBox[{"GS", "[", "p1", "]"}], "+", "me"}], ")"}], ".", 
      RowBox[{"GA", "[", "\[Mu]", "]"}], ".", 
      RowBox[{"SpinorU", "[", 
       RowBox[{"p2", ",", "me"}], "]"}]}], ")"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Amp2", "=", 
   RowBox[{"gaee", "*", 
    FractionBox["qe", 
     RowBox[{
      SuperscriptBox["ma", "2"], "+", 
      RowBox[{"2", "*", 
       RowBox[{"ScalarProduct", "[", 
        RowBox[{"p1", ",", "p2"}], "]"}]}]}]], "*", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"SpinorUBar", "[", 
       RowBox[{"k2", ",", "me"}], "]"}], ".", 
      RowBox[{"GA", "[", "\[Mu]", "]"}], ".", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"GS", "[", "p1", "]"}], "+", 
        RowBox[{"GS", "[", "p2", "]"}], "+", "me"}], ")"}], ".", 
      RowBox[{"GA", "[", "5", "]"}], ".", 
      RowBox[{"SpinorU", "[", 
       RowBox[{"p2", ",", "me"}], "]"}]}], ")"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"CompConjAmp1", "=", 
   RowBox[{"ComplexConjugate", "[", 
    RowBox[{"Amp1", "/.", 
     RowBox[{"{", 
      RowBox[{"\[Mu]", "->", "\[Nu]"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"CompConjAmp2", "=", 
   RowBox[{"ComplexConjugate", "[", 
    RowBox[{"Amp2", "/.", 
     RowBox[{"{", 
      RowBox[{"\[Mu]", "->", "\[Nu]"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"SetMandelstam", "[", 
   RowBox[{"s", ",", "t", ",", "u", ",", "p1", ",", "p2", ",", 
    RowBox[{"-", "k1"}], ",", 
    RowBox[{"-", "k2"}], ",", "ma", ",", "me", ",", "0", ",", "me"}], "]"}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Res1", "=", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{"Contract", "[", 
     RowBox[{"DiracSimplify", "[", 
      RowBox[{"FermionSpinSum", "[", 
       RowBox[{
        FractionBox["1", "2"], "*", 
        RowBox[{"Amp1", ".", "CompConjAmp1", ".", 
         RowBox[{"MT", "[", 
          RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}]}]}], "]"}], "]"}], "]"}], 
    "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Res2", "=", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{"Contract", "[", 
     RowBox[{"DiracSimplify", "[", 
      RowBox[{"FermionSpinSum", "[", 
       RowBox[{
        FractionBox["1", "2"], "*", 
        RowBox[{"Amp2", ".", "CompConjAmp2", ".", 
         RowBox[{"MT", "[", 
          RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}]}]}], "]"}], "]"}], "]"}], 
    "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Res3", "=", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{"Contract", "[", 
     RowBox[{"DiracSimplify", "[", 
      RowBox[{"FermionSpinSum", "[", 
       RowBox[{
        FractionBox["1", "2"], "*", 
        RowBox[{"Amp1", ".", "CompConjAmp2", ".", 
         RowBox[{"MT", "[", 
          RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}]}]}], "]"}], "]"}], "]"}], 
    "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Res4", "=", 
