      RowBox[{
       RowBox[{"2", "*", 
        SuperscriptBox["me", "2"]}], "+", 
       SuperscriptBox["ma", "2"], "-", "s", "-", "t"}]}], "}"}]}], 
   "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"dsigmadt", "=", 
