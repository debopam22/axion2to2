Cell[BoxData[{
 RowBox[{
  RowBox[{"Amp1", "=", 
   RowBox[{"gaee", "*", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"SpinorUBar", "[", 
       RowBox[{"k1", ",", " ", "me"}], "]"}], ".", " ", 
      RowBox[{"GA", "[", "5", "]"}], ".", 
      RowBox[{"SpinorV", "[", 
       RowBox[{"k2", ",", "me"}], "]"}]}], ")"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"CompConjAmp1", "=", 
   RowBox[{"ComplexConjugate", "[", "Amp1", "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"Res", "=", 
  RowBox[{"FullSimplify", "[", 
   RowBox[{"DiracSimplify", "[", 
    RowBox[{"FermionSpinSum", "[", 
     RowBox[{"Amp1", ".", "CompConjAmp1"}], "]"}], "]"}], "]"}]}]}], "Input",
 CellChangeTimes->{{3.958025232664732*^9, 3.95802523338631*^9}, {
  3.958025340379113*^9, 3.958025343410759*^9}},
