          RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}]}]}], "]"}], "]"}], "]"}], 
    "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Amp2", "=", 
