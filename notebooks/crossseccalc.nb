Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"Amp1", "=", 
   RowBox[{"gaaa", "*", 
    RowBox[{"Eps", "[", 
     RowBox[{
      RowBox[{"LorentzIndex", "[", "\[Mu]", "]"}], ",", " ", 
      RowBox[{"LorentzIndex", "[", "\[Nu]", "]"}], ",", " ", 
      RowBox[{"LorentzIndex", "[", "\[Rho]", "]"}], ",", " ", 
      RowBox[{"LorentzIndex", "[", "\[Sigma]", "]"}]}], "]"}], "*", 
    RowBox[{"FV", "[", 
     RowBox[{"k1", ",", " ", "\[Rho]"}], "]"}], "*", 
    RowBox[{"FV", "[", 
     RowBox[{"k2", ",", " ", "\[Sigma]"}], "]"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"CompConjAmp1", "=", 
   RowBox[{"ComplexConjugate", "[", 
    RowBox[{"Amp1", "/.", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"\[Mu]", "->", "\[Mu]1"}], ",", " ", 
       RowBox[{"\[Nu]", "->", "\[Nu]1"}]}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Res", "=", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{"DiracSimplify", "[", 
     RowBox[{"FermionSpinSum", "[", 
      RowBox[{"EpsEvaluate", "[", 
       RowBox[{"Contract", "[", 
        RowBox[{"Amp1", ".", "CompConjAmp1", ".", 
         RowBox[{"MT", "[", 
          RowBox[{"\[Mu]", ",", "\[Mu]1"}], "]"}], ".", 
         RowBox[{"MT", "[", 
          RowBox[{"\[Nu]", ",", "\[Nu]1"}], "]"}]}], "]"}], "]"}], "]"}], 
     "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"TraditionalForm", "[", "Res", "]"}]}], "Input",
 CellChangeTimes->{{3.958021378320114*^9, 3.958021385954129*^9}},
 CellLabel->"In[2]:=",ExpressionUUID->"ff929c9e-747c-48e3-a26f-696823f2afd4"],

Cell[BoxData[
 FormBox[
  RowBox[{"2", " ", 
   SuperscriptBox["gaaa", "2"], " ", 
   RowBox[{"(", 
    RowBox[{
     SuperscriptBox[
      RowBox[{
       FormBox["\<\"(\"\>",
        TraditionalForm], 
       FormBox[
        RowBox[{
         FormBox[
          OverscriptBox[
           FormBox["k1",
            TraditionalForm], "_"],
          TraditionalForm], 
         FormBox["\<\"\[CenterDot]\"\>",
          TraditionalForm], 
         FormBox[
          OverscriptBox[
           FormBox["k2",
            TraditionalForm], "_"],
          TraditionalForm]}],
        TraditionalForm], 
       FormBox["\<\")\"\>",
        TraditionalForm]}], "2"], "-", 
     RowBox[{
      SuperscriptBox[
       FormBox[
        OverscriptBox[
         FormBox["k1",
          TraditionalForm], "_"],
        TraditionalForm], "2"], " ", 
      SuperscriptBox[
       FormBox[
        OverscriptBox[
         FormBox["k2",
          TraditionalForm], "_"],
        TraditionalForm], "2"]}]}], ")"}]}], TraditionalForm]], "Output",
 CellChangeTimes->{3.9580213878501053`*^9},
 CellLabel->
  "Out[5]//TraditionalForm=",ExpressionUUID->"1824d39f-c977-4fff-aae4-\
643d1c3be56c"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\



Inverse Primakoff Scattering : a(p1) + N (p2) -- > \[Gamma] (k1) + N (k2) via \
an exchange of \[Gamma]\
\>", "Subtitle",
 CellChangeTimes->{{3.9580219411315613`*^9, 
  3.9580219596860456`*^9}},ExpressionUUID->"9e0fcd84-e5ae-4dc0-91b4-\
af2ed16b0804"],

Cell["\<\
Considered the nucleus at rest initially and the axion comes and hit it. mphi \
is the axion mass and gaaa is the coupling between photons and axion. Form \
factor has been considered to be 1 here.\
\>", "Text",
 CellChangeTimes->{{3.9829232624933023`*^9, 3.9829232947467546`*^9}, {
  3.982937967299518*^9, 
  3.982937976058091*^9}},ExpressionUUID->"ee45a0e8-1362-4aac-b2e2-\
cba3950dd18e"],

