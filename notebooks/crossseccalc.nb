   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{"-", "1"}], ")"}], "*", 
     RowBox[{"(", 
      RowBox[{"Res1", "+", "Res2", "+", "Res3", "+", "Res4"}], ")"}]}], "/.", 
    
    RowBox[{"{", 
