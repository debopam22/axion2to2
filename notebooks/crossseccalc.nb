Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"Amp1", "=", 
   RowBox[{"Z", "*", "qe", "*", "gaaa", "*", 
    FractionBox["1", 
     RowBox[{
      RowBox[{"ScalarProduct", "[", 
       RowBox[{"p2", ",", "p2"}], "]"}], "+", 
      RowBox[{"ScalarProduct", "[", 
       RowBox[{"k2", ",", "k2"}], "]"}], "-", 
      RowBox[{"2", "*", 
       RowBox[{"ScalarProduct", "[", 
        RowBox[{"p2", ",", "k2"}], "]"}]}]}]], "*", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"SpinorUBar", "[", 
       RowBox[{"k2", ",", "mN"}], "]"}], ".", 
      RowBox[{"GA", "[", "\[Mu]", "]"}], ".", 
      RowBox[{"SpinorU", "[", 
       RowBox[{"p2", ",", "mN"}], "]"}]}], ")"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Amp2", "=", 
   RowBox[{
    RowBox[{"Eps", "[", 
     RowBox[{
      RowBox[{"LorentzIndex", "[", "\[Mu]", "]"}], ",", " ", 
      RowBox[{"LorentzIndex", "[", "\[Nu]", "]"}], ",", " ", 
      RowBox[{"LorentzIndex", "[", "\[Rho]", "]"}], ",", " ", 
      RowBox[{"LorentzIndex", "[", "\[Sigma]", "]"}]}], "]"}], "*", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"FV", "[", 
       RowBox[{"p2", ",", " ", "\[Rho]"}], "]"}], "-", 
      RowBox[{"FV", "[", 
       RowBox[{"k2", ",", "\[Rho]"}], "]"}]}], ")"}], "*", 
    RowBox[{"FV", "[", 
     RowBox[{"k1", ",", " ", "\[Sigma]"}], "]"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"CompConjAmp1", "=", 
   RowBox[{"ComplexConjugate", "[", 
    RowBox[{"Amp1", "/.", 
     RowBox[{"{", 
      RowBox[{"\[Mu]", "->", "\[Alpha]"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"CompConjAmp2", "=", 
   RowBox[{"ComplexConjugate", "[", 
    RowBox[{"Amp2", "/.", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"\[Mu]", "->", "\[Alpha]"}], ",", 
       RowBox[{"\[Nu]", "->", "\[Beta]"}]}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"SetMandelstam", "[", 
   RowBox[{"s", ",", "t", ",", "u", ",", "p1", ",", "p2", ",", 
    RowBox[{"-", "k1"}], ",", 
    RowBox[{"-", "k2"}], ",", "mphi", ",", "mN", ",", "0", ",", "mN"}], "]"}],
   ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Res1", "=", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{"Contract", "[", 
     RowBox[{"DiracSimplify", "[", 
      RowBox[{"FermionSpinSum", "[", 
       RowBox[{
        FractionBox["1", "2"], "*", 
        RowBox[{"Amp1", ".", "CompConjAmp1"}]}], "]"}], "]"}], "]"}], "]"}]}],
   ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Res2", "=", 
   RowBox[{"FullSimplify", "[", 
    RowBox[{"Contract", "[", 
     RowBox[{"DiracSimplify", "[", 
      RowBox[{"FermionSpinSum", "[", 
       RowBox[{"Amp2", ".", "CompConjAmp2", ".", 
        RowBox[{"MT", "[", 
         RowBox[{"\[Nu]", ",", "\[Beta]"}], "]"}]}], "]"}], "]"}], "]"}], 
    "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Amp2", "=", 
  RowBox[{"FullSimplify", "[", 
   RowBox[{
    RowBox[{"Contract", "[", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"-", "1"}], ")"}], "*", 
      RowBox[{"Res1", ".", "Res2"}]}], "]"}], "/.", 
    RowBox[{"{", 
     RowBox[{"u", "->", 
      RowBox[{
       RowBox[{"2", "*", 
        SuperscriptBox["mN", "2"]}], "+", 
       SuperscriptBox["mphi", "2"], "-", "s", "-", "t"}]}], "}"}]}], 
   "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"dsigmadt", "=", 
   FractionBox["Amp2", 
    RowBox[{"64", "*", "Pi", "*", 
     FractionBox[
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"s", "-", 
         SuperscriptBox["mN", "2"]}], ")"}], "2"], "4"]}]]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"Amp3", "=", 
  RowBox[{"FullSimplify", "[", 
   RowBox[{"dsigmadt", "/.", 
    RowBox[{"{", 
     RowBox[{"s", "->", 
      RowBox[{
       SuperscriptBox["mN", "2"], "+", 
       RowBox[{"2", "*", "Ega", "*", "mN"}]}]}], "}"}]}], "]"}]}]}], "Input",
 CellChangeTimes->{{3.9580224294742126`*^9, 3.958022446797228*^9}, {
   3.958022553270194*^9, 3.958022553671979*^9}, 3.982923245720317*^9},
